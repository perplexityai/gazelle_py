# Pin the host platform on Linux so rules_rs's Rust toolchains (used by the
# gazelle plugin's import_extractor staticlib) match the libc:gnu.2.28
# constraint they tag via target_compatible_with. This is the only reason
# bcr_test/ exists as a separate workspace — BCR's sandbox doesn't read the
# top-level .bazelrc, so building @gazelle_py//... directly from BCR fails
# on Ubuntu without this pin. macOS doesn't need it.
common --enable_platform_specific_config
# Use the platform defined inside this main repo (`//platforms:local_gnu`)
# instead of `@gazelle_py//platforms:local_gnu`. BCR's runner shells out
# to `bazel info` before any build, and `info` doesn't trigger module
# resolution — any --host_platform label outside the main repo fails to
# parse with "Repository '@@gazelle_py' is not defined" before the build
# can even start. Main-repo labels are always resolvable.
common:linux --host_platform=//platforms:local_gnu

build --show_result=0
test --test_output=errors
