# Pin the host platform on Linux so rules_rs's Rust toolchains (used by the
# gazelle plugin's import_extractor staticlib) match the libc:gnu.2.28
# constraint they tag via target_compatible_with. This is the only reason
# bcr_test/ exists as a separate workspace — BCR's sandbox doesn't read the
# top-level .bazelrc, so building @gazelle_py//... directly from BCR fails
# on Ubuntu without this pin. macOS doesn't need it.
common --enable_platform_specific_config
# Scope the host_platform pin to build/test (not `common`). BCR's runner
# does `bazel info` before any actual build, and `info` doesn't resolve
# module deps — so a `common:linux --host_platform=@gazelle_py//...`
# would fail with "Repository '@@gazelle_py' is not defined" before
# anything useful happens. `build:` and `test:` only apply to those
# subcommands, by which point bzlmod has loaded our deps and the label
# resolves cleanly.
build:linux --host_platform=@gazelle_py//platforms:local_gnu
test:linux --host_platform=@gazelle_py//platforms:local_gnu

build --show_result=0
test --test_output=errors
