build --registry=https://bcr.bazel.build

# Pin the host platform on Linux so rules_rs's Rust toolchains (used by the
# gazelle plugin's import_extractor staticlib) match the Linux GNU libc
# constraint they tag via target_compatible_with. macOS doesn't need this.
common --enable_platform_specific_config
common:linux --host_platform=@gazelle_py//platforms:local_gnu

# Hermetic posture: @gazelle_py's MODULE.bazel registers @llvm//toolchain:all.
# Disabling Bazel's autodetected CC/Apple/Swift toolchains keeps the hermetic
# llvm clang as the only cc toolchain in scope (avoids the
# XcodeLocalEnvProvider duplicate-SDKROOT crash on macOS hosts with Xcode and
# the host-gcc-vs-llvm race on linux). The libgcc_s stub satisfies
# rules_rust's hardcoded `-lgcc_s` link spec on linux against compiler-rt.
common --repo_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1
common --repo_env=BAZEL_NO_APPLE_CPP_TOOLCHAIN=1
common --repo_env=BAZEL_DO_NOT_DETECT_SWIFT_TOOLCHAIN=1
common --@llvm//config:experimental_stub_libgcc_s=True

# rules_go's external link calls cc; clang+lld defaults to PIE on linux but
# Go produces R_X86_64_64 relocations that need -no-pie.
build:linux --linkopt=-no-pie

# Quieter output.
build --show_result=0
test --test_output=errors

# Local user overrides.
try-import %workspace%/.bazelrc.user
