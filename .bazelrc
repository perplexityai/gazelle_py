# Bazel 9: bzlmod is the only mode; WORKSPACE is gone.

build --registry=https://bcr.bazel.build

# Use the hermetic @llvm cc toolchain (registered in MODULE.bazel); disabling
# autodetect avoids XcodeLocalEnvProvider's duplicate-SDKROOT crash on macOS
# hosts with Xcode. Stub libgcc_s so rules_rust tool binaries avoid a
# non-hermetic system libgcc_s dependency.
common --repo_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1
common --repo_env=BAZEL_NO_APPLE_CPP_TOOLCHAIN=1
common --@llvm//config:experimental_stub_libgcc_s=True

# Go 1.27 (Aug 2026) makes Go binaries PIE-compatible — drop this then.
# Until then, rules_go's external link via clang+lld needs -no-pie because
# Go uses R_X86_64_64 relocations.
build:linux --linkopt=-no-pie

# Per rules_rs's paved path: pin the host platform on Linux and Windows so
# rust toolchain resolution can pick the right exec toolchain. macOS doesn't
# need this. See //platforms:BUILD.bazel for the platform definitions.
common --enable_platform_specific_config
common:linux --host_platform=//platforms:local_gnu
common:windows --host_platform=//platforms:local_windows_msvc

# Quieter output
build --show_result=0
test --test_output=errors

# Release builds: opt-level 3, single codegen unit, abort on panic, strip symbols, thin LTO.
# Keeps the published binary small and matches Cargo's [profile.release] settings.
build:opt --compilation_mode=opt
build:opt --@rules_rust//:extra_rustc_flags=-Ccodegen-units=1,-Cpanic=abort,-Cstrip=symbols,-Clto=thin,-Cembed-bitcode=yes

# Local user overrides
try-import %workspace%/.bazelrc.user
